{
  "name": "@pods/backend",
  "version": "1.0.0",
  "description": "Pods backend API using Serverless Framework",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npx serverless offline --config serverless-local.yml",
    "dev:aws": "serverless offline",
    "dev:db": "docker-compose up -d && npx serverless offline --config serverless-local.yml",
    "dev:local-db": "serverless dynamodb start --migrate && serverless offline",
    "build": "tsc",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:prod": "serverless deploy --stage prod",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:api": "node test-user-api.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf .serverless .webpack .build",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:create-tables": "node scripts/create-tables.js",
    "db:setup": "npm run db:start && sleep 3 && npm run db:create-tables",
    "dev:full": "npm run db:setup && npx serverless offline --config serverless-local.yml",
    "dynamodb:install": "serverless dynamodb install",
    "dynamodb:start": "serverless dynamodb start --migrate"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.450.0",
    "@aws-sdk/client-dynamodb": "^3.450.0",
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/lib-dynamodb": "^3.450.0",
    "aws-lambda": "^1.0.7",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.20.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "serverless": "^3.38.0",
    "serverless-dynamodb-local": "^0.2.40",
    "serverless-offline": "^13.3.0",
    "serverless-plugin-typescript": "^2.1.5",
    "serverless-webpack": "^5.13.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^6.0.1"
  }
}
